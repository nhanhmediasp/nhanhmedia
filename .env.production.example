# ==============================================================
#  BIẾN MÔI TRƯỜNG CHO PRODUCTION (Vercel)
#  Sao chép từng biến này vào Vercel Dashboard > Settings > Environment Variables
# ==============================================================

# ---------------------------------------------------------------
# DATABASE (Bắt buộc)
# Lấy từ Neon.tech hoặc Supabase sau khi tạo project
# ---------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ---------------------------------------------------------------
# AUTHENTICATION (Bắt buộc - PHẢI đổi sang giá trị ngẫu nhiên)
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ---------------------------------------------------------------
JWT_SECRET="thay_bang_chuoi_ngau_nhien_it_nhat_64_ky_tu"

# ---------------------------------------------------------------
# CRON JOB PROTECTION (Bắt buộc - PHẢI đổi)
# Vercel Cron sẽ inject header: Authorization: Bearer <CRON_SECRET>
# ---------------------------------------------------------------
CRON_SECRET="thay_bang_chuoi_ngau_nhien_it_nhat_32_ky_tu"

# ---------------------------------------------------------------
# MÃ HÓA MẬT KHẨU SMTP (Bắt buộc - PHẢI đổi)
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Phải là chuỗi 64 ký tự hex (32 bytes)
# ---------------------------------------------------------------
SMTP_ENCRYPTION_KEY="thay_bang_64_ky_tu_hex_ngau_nhien_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------
# NODE ENV (Tự động đặt bởi Vercel, không cần thêm thủ công)
# ---------------------------------------------------------------
# NODE_ENV="production"
