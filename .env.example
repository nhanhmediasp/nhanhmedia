# ============================================================
# NhanhMedia – Environment Variables Template
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env thật lên Git
# ============================================================

# Database – MySQL/MariaDB trên aaPanel
# Thay USER, PASSWORD, DATABASE_NAME bằng thông tin thực
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME"

# Authentication – JWT Secret (bắt buộc, tối thiểu 32 ký tự)
# Tạo ngẫu nhiên: openssl rand -hex 32
JWT_SECRET="change_me_random_64_char_string_here_do_not_use_in_production"

# Cron Protection Token (dùng để bảo vệ endpoint /api/cron/reminders)
CRON_SECRET="change_me_cron_secret_key"

# Crypto – Khóa mã hóa SMTP Password (bắt buộc: đúng 64 ký tự hex = 32 bytes)
# Tạo: openssl rand -hex 32
SMTP_ENCRYPTION_KEY="d7c95a289b4b0e515d48721c5a92a543ee7d216f9fdfa7ab725841cb648b292e"

# URL công khai của website (không có dấu / ở cuối)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
